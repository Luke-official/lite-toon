# Lite-Toon — environment variables (demo app)
# Copy to apps/demo/.env.local for local overrides, or export before running test scripts.
#
#   cp .env.example apps/demo/.env.local

# OAuth client ID exposed to ChatGPT / Claude / Gemini during the demo flow.
# Default in code: lite-toon-demo
OAUTH_CLIENT_ID=lite-toon-demo

# Base URL used by apps/demo/scripts/test-*.js (optional; defaults to http://localhost:3000)
BASE_URL=http://localhost:3000
