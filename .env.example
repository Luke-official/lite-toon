# Lite-Toon — environment variables (demo app)
# Copy to apps/demo/.env.local for local overrides, or export before running test scripts.
#
#   cp .env.example apps/demo/.env.local

# OAuth client ID exposed to ChatGPT / Claude / Gemini during the demo flow.
# Default in code: lite-toon-demo
OAUTH_CLIENT_ID=lite-toon-demo

# Base URL used by apps/demo/scripts/test-*.js (optional; defaults to http://localhost:3000)
# When testing Claude via ngrok, set this to your tunnel URL:
# BASE_URL=https://abc123.ngrok-free.app
BASE_URL=http://localhost:3000

# Extra OAuth redirect URIs (comma-separated), e.g. a stable ngrok domain
# OAUTH_EXTRA_REDIRECT_URIS=https://my-tunnel.ngrok-free.app/oauth/callback

# Extra Next.js dev origins (comma-separated hostnames, optional)
# Wildcards *.ngrok-free.app are already in next.config.ts
# ALLOWED_DEV_ORIGINS=fa36-151-54-119-141.ngrok-free.app
